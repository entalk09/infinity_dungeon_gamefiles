code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D tex_frg_8 : source_color;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;


// VectorOp:3
	vec2 n_in3p1 = vec2(0.50000, 0.50000);
	vec2 n_out3p0 = n_out2p0 - n_in3p1;


// VectorOp:4
	vec2 n_out4p0 = n_out3p0 * n_out3p0;
	float n_out4p1 = n_out4p0.r;
	float n_out4p2 = n_out4p0.g;


// FloatOp:5
	float n_in5p1 = 3.00000;
	float n_out5p0 = n_out4p1 * n_in5p1;


// FloatOp:6
	float n_out6p0 = n_out5p0 + n_out4p2;


// MultiplyAdd:7
	float n_in7p1 = -1.00000;
	float n_in7p2 = 0.50000;
	float n_out7p0 = fma(n_out6p0, n_in7p1, n_in7p2);


// Input:10
	vec2 n_out10p0 = UV;
	float n_out10p1 = n_out10p0.r;
	float n_out10p2 = n_out10p0.g;


// Input:12
	float n_out12p0 = TIME;


// FloatFunc:18
	float n_out18p0 = fract(n_out12p0);


// FloatOp:21
	float n_in21p0 = 1.00000;
	float n_out21p0 = n_in21p0 - n_out18p0;


// MultiplyAdd:17
	float n_in17p1 = 0.50000;
	float n_in17p2 = 0.25000;
	float n_out17p0 = fma(n_out21p0, n_in17p1, n_in17p2);


// VectorCompose:13
	vec2 n_out13p0 = vec2(n_out10p1, n_out17p0);


// FloatOp:15
	float n_out15p0 = n_out21p0 - n_out10p2;


// FloatOp:16
	float n_in16p1 = 1.00000;
	float n_out16p0 = n_out15p0 * n_in16p1;


// VectorCompose:19
	float n_in19p0 = 0.00000;
	vec2 n_out19p0 = vec2(n_in19p0, n_out16p0);


// UVFunc:9
	vec2 n_in9p1 = vec2(1.00000, 1.00000);
	vec2 n_out9p0 = n_out19p0 * n_in9p1 + n_out13p0;


// VectorDecompose:24
	float n_out24p0 = n_out9p0.x;
	float n_out24p1 = n_out9p0.y;


// Compare:23
	float n_in23p1 = 1.00000;
	bool n_out23p0 = n_out24p1 > n_in23p1;


// FloatOp:26
	float n_in26p1 = 1.00000;
	float n_out26p0 = n_out24p1 - n_in26p1;


	float n_out25p0;
// Switch:25
	n_out25p0 = mix(n_out24p1, n_out26p0, float(n_out23p0));


// VectorCompose:27
	vec2 n_out27p0 = vec2(n_out24p0, n_out25p0);


// Texture2D:8
	vec4 n_out8p0 = texture(tex_frg_8, n_out27p0);


// Step:28
	vec2 n_in28p0 = vec2(0.50000, 0.50000);
	vec2 n_out28p0 = step(n_in28p0, vec2(n_out8p0.xy));


// FloatOp:22
	float n_out22p0 = n_out7p0 * n_out28p0.x;


// Output:0
	COLOR.a = n_out22p0;


}
